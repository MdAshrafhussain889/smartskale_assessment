# Matches docker-compose.yml (user hiremind, password password, db hiremind)
DATABASE_URL=postgresql://hiremind:password@127.0.0.1:5432/hiremind

REDIS_URL=redis://localhost:6379/0

OPENAI_API_KEY=your_openai_api_key

# Free: self-host Judge0 (see docker-compose.judge0.yml) — no API key needed
JUDGE0_API_URL=http://127.0.0.1:2358
JUDGE0_API_KEY=
# Paid optional: RapidAPI — only if you use https://judge0-ce.p.rapidapi.com
# JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
# JUDGE0_API_KEY=your_rapidapi_key

JWT_SECRET=your_secret_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://127.0.0.1:8000

ENVIRONMENT=development

PROCTORING_ENABLED=true
AI_EVALUATION_ENABLED=true
